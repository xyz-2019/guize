[custom]
enable_rule_generator=false
overwrite_original_rules=false

; =========================
; 1. 本地
; =========================

ruleset=DIRECT,[]GEOSITE,private
ruleset=DIRECT,[]GEOSITE,cn

; =========================
; 2. AI
; =========================

ruleset=🤖 ChatGPT,[]GEOSITE,openai
ruleset=🧠 AI,[]GEOSITE,category-ai-!cn

; =========================
; 3. 流媒体
; =========================

ruleset=🎬 YouTube,[]GEOSITE,youtube
ruleset=🎥 Netflix,[]GEOSITE,netflix
ruleset=📺 Disney,[]GEOSITE,disney
ruleset=🎵 TikTok,[]GEOSITE,tiktok

; =========================
; 4. 工具
; =========================

ruleset=🛠 GitHub,[]GEOSITE,github
ruleset=🔎 Google,[]GEOSITE,google
ruleset=🪟 Microsoft,[]GEOSITE,microsoft
ruleset=☁️ cloudflare,[]GEOSITE,cloudflare

; =========================
; 5. 社交
; =========================

ruleset=🐦 X,[]GEOSITE,twitter

ruleset=📨 Telegram,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Telegram/Telegram.list

; =========================
; 6. GFW
; =========================

ruleset=🚀 手动选择,[]GEOSITE,gfw

; =========================
; 7. 兜底
; =========================

ruleset=🌐 Default,[]FINAL
custom_proxy_group=🌐 Default`select`[]🚀 手动选择`[]DIRECT`[]REJECT

custom_proxy_group=🚀 手动选择`select`[]DIRECT`[]美国`[]新加坡`[]日本

custom_proxy_group=🤖 ChatGPT`select`[]美国`[]新加坡`[]🚀 手动选择
custom_proxy_group=🧠 AI`select`[]美国`[]新加坡`[]🚀 手动选择

custom_proxy_group=🎬 YouTube`select`[]美国`[]日本`[]🚀 手动选择
custom_proxy_group=🎥 Netflix`select`[]美国`[]日本`[]REJECT
custom_proxy_group=📺 Disney`select`[]美国`[]日本`[]REJECT

custom_proxy_group=🎵 TikTok`select`[]美国`[]日本`[]🚀 手动选择
custom_proxy_group=🛠 GitHub`select`[]美国`[]🚀 手动选择
custom_proxy_group=🔎 Google`select`[]美国`[]🚀 手动选择
custom_proxy_group=🪟 Microsoft`select`[]DIRECT`[]美国
custom_proxy_group=☁️ cloudflare`select`[]DIRECT`[]美国
