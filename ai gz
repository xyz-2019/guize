[custom]
enable_rule_generator=true
overwrite_original_rules=true

; =========================================================
; 1. 本地 / 内网（最高优先级）
; =========================================================

ruleset=DIRECT,[]GEOSITE,private
ruleset=DIRECT,GEOIP,private,no-resolve

ruleset=DIRECT,[]GEOSITE,cn
ruleset=DIRECT,GEOIP,CN,no-resolve

; =========================================================
; 2. AI / 高价值流量（强制低延迟）
; =========================================================

ruleset=🤖 ChatGPT,[]GEOSITE,openai
ruleset=🧠 AI,[]GEOSITE,category-ai-!cn

ruleset=🤖 ChatGPT,GEOIP,openai,no-resolve

; =========================================================
; 3. 流媒体（独立优化）
; =========================================================

ruleset=🎬 YouTube,[]GEOSITE,youtube

ruleset=🎥 Netflix,[]GEOSITE,netflix
ruleset=🎥 Netflix,GEOIP,netflix,no-resolve

ruleset=📺 Disney,[]GEOSITE,disney
ruleset=📺 Disney,GEOIP,disney,no-resolve

ruleset=🎵 TikTok,[]GEOSITE,tiktok
ruleset=🎵 TikTok,GEOIP,tiktok,no-resolve

; =========================================================
; 4. 开发 / 科技（稳定优先）
; =========================================================

ruleset=🛠 GitHub,[]GEOSITE,github
ruleset=🛠 GitHub,GEOIP,github,no-resolve

ruleset=🔎 Google,[]GEOSITE,google
ruleset=🪟 Microsoft,[]GEOSITE,microsoft
ruleset=☁️ cloudflare,[]GEOSITE,cloudflare

ruleset=🔎 Google,GEOIP,google,no-resolve
ruleset=🪟 Microsoft,GEOIP,microsoft,no-resolve
ruleset=☁️ cloudflare,GEOIP,cloudflare,no-resolve

; =========================================================
; 5. 社交通信
; =========================================================

ruleset=🐦 X,[]GEOSITE,twitter

ruleset=📨 Telegram,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Telegram/Telegram.list

; =========================================================
; 6. GFW（统一墙外流量）
; =========================================================

ruleset=🚀 智能出口,[]GEOSITE,gfw

; =========================================================
; 7. 最终兜底
; =========================================================

ruleset=🌐 终极出口,[]FINAL


; =========================================================
; 1. 智能出口（核心）
; =========================================================

custom_proxy_group=🌐 终极出口`select`[]🚀 自动优选`[]美国低延迟`[]新加坡低延迟`[]日本低延迟`[]DIRECT`[]REJECT

custom_proxy_group=🚀 自动优选`url-test`.*`https://www.gstatic.com/generate_204`120,,30

; =========================================================
; 2. 低延迟国家池（核心优化）
; =========================================================

custom_proxy_group=美国低延迟`url-test`(US|美国|洛杉矶|硅谷|达拉斯|芝加哥)`https://www.gstatic.com/generate_204`120,,30
custom_proxy_group=新加坡低延迟`url-test`(SG|新加坡|狮城)`https://www.gstatic.com/generate_204`120,,30
custom_proxy_group=日本低延迟`url-test`(JP|日本|东京|大阪)`https://www.gstatic.com/generate_204`120,,30

; =========================================================
; 3. AI（重点优化路径）
; =========================================================

custom_proxy_group=🤖 ChatGPT`select`[]美国低延迟`[]新加坡低延迟`[]🚀 自动优选`[]DIRECT
custom_proxy_group=🧠 AI`select`[]美国低延迟`[]新加坡低延迟`[]🚀 自动优选`[]DIRECT

; =========================================================
; 4. 流媒体优化
; =========================================================

custom_proxy_group=🎬 YouTube`select`[]美国低延迟`[]日本低延迟`[]🚀 自动优选

custom_proxy_group=🎥 Netflix`select`[]美国低延迟`[]日本低延迟`[]REJECT
custom_proxy_group=📺 Disney`select`[]美国低延迟`[]日本低延迟`[]REJECT

custom_proxy_group=🎵 TikTok`select`[]美国低延迟`[]日本低延迟`[]🚀 自动优选

; =========================================================
; 5. 开发工具（稳定优先）
; =========================================================

custom_proxy_group=🛠 GitHub`select`[]美国低延迟`[]🚀 自动优选`[]DIRECT
custom_proxy_group=🔎 Google`select`[]美国低延迟`[]🚀 自动优选`[]DIRECT
custom_proxy_group=🪟 Microsoft`select`[]DIRECT`[]美国低延迟`[]🚀 自动优选
custom_proxy_group=☁️ cloudflare`select`[]DIRECT`[]美国低延迟

; =========================================================
; 6. 社交
; =========================================================

custom_proxy_group=🐦 X`select`[]美国低延迟`[]🚀 自动优选

custom_proxy_group=📨 Telegram`select`[]新加坡低延迟`[]美国低延迟`[]🚀 自动优选
